import os
import json
import numpy as np
from sentence_transformers import SentenceTransformer
import faiss

class LocalMemory:
    def __init__(self, kb_path="data/cns_knowledge_base"):
        self.kb_path = kb_path
        os.makedirs(kb_path, exist_ok=True)
        self.model = SentenceTransformer('all-MiniLM-L6-v2', device='cpu')
        self.index = None
        self.metadata = []
        self._load_or_build_index()
    
    def _load_or_build_index(self):
        index_file = os.path.join(self.kb_path, "faiss.index")
        meta_file = os.path.join(self.kb_path, "metadata.json")
        if os.path.exists(index_file) and os.path.exists(meta_file):
            self.index = faiss.read_index(index_file)
            with open(meta_file, 'r') as f:
                self.metadata = json.load(f)
        else:
            # 初始化空索引
            self.index = faiss.IndexFlatIP(384)
            self.metadata = []
    
    def _save_index(self):
        faiss.write_index(self.index, os.path.join(self.kb_path, "faiss.index"))
        with open(os.path.join(self.kb_path, "metadata.json"), 'w') as f:
            json.dump(self.metadata, f, indent=2)
    
    def _get_embedding(self, text):
        return self.model.encode([text])[0].astype(np.float32)
    
    def search(self, topic, section, threshold=0.75):
        if self.index.ntotal == 0:
            return None
        query_embed = self._get_embedding(f"{topic} {section}")
        distances, indices = self.index.search(np.array([query_embed]), k=3)
        for i, idx in enumerate(indices[0]):
            if distances[0][i] >= threshold:
                meta = self.metadata[idx]
                if meta["section"] == section:
                    return meta["content"]
        return None
    
    def store(self, topic, section, content):
        embed = self._get_embedding(f"{topic} {section} {content[:200]}")
        self.index.add(np.array([embed]))
        self.metadata.append({
            "topic": topic,
            "section": section,
            "content": content
        })
        self._save_index()